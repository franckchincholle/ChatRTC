{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "./dist-electron",
    "rootDir": "./electron",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "type": ["node", "electron"]
  },
  "include": ["electron/**/*.ts"],
  "exclude": ["node_modules", "dist-electron", ".next"]
}
