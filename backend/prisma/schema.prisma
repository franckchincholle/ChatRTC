generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String   
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  ownedServers      Server[]        @relation("OwnedServers")      
  serverMemberships ServerMember[]  @relation("UserMemberships")   
  messages          Message[]       @relation("UserMessages")
  bansGiven         ServerBan[]     @relation("BansGiven")
  bansReceived      ServerBan[]     @relation("BansReceived")
  reactions         Reaction[]      @relation("UserReactions")
}

model Server {
  id        String   @id @default(uuid())
  name      String   @unique 
  ownerId   String   
  createdAt DateTime @default(now()) 
  updatedAt DateTime @updatedAt

  // Relations
  owner       User           @relation("OwnedServers", fields: [ownerId], references: [id])
  channels    Channel[]      @relation("OwnedChannels")       
  members     ServerMember[] @relation("ServerMemberships")   
  invitations Invitation[]   @relation("ServerInvitations")
  bans        ServerBan[]    @relation("ServerBans")   
}

model Channel {
  id        String   @id @default(uuid())
  name      String   
  serverId  String   
  createdAt DateTime @default(now()) 
  updatedAt DateTime @updatedAt

  // Relations
  server   Server    @relation("OwnedChannels", fields: [serverId], references: [id], onDelete: Cascade)
  messages Message[] @relation("ChannelMessages")  

  @@unique([serverId, name])
}

model Message {
  id        String   @id @default(uuid())
  content   String
  channelId String
  userId    String
  createdAt DateTime @default(now()) 
  updatedAt DateTime @updatedAt

  // Relations
  author    User       @relation("UserMessages", fields: [userId], references: [id], onDelete: Cascade)
  channel   Channel    @relation("ChannelMessages", fields: [channelId], references: [id], onDelete: Cascade)
  reactions Reaction[] @relation("MessageReactions")
}

model Reaction {
  id        String   @id @default(uuid())
  emoji     String
  messageId String
  userId    String
  createdAt DateTime @default(now())

  // Relations
  message Message @relation("MessageReactions", fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation("UserReactions",    fields: [userId],    references: [id], onDelete: Cascade)

  // Un seul emoji par utilisateur par message
  @@unique([messageId, userId])
}

model ServerMember {
  id        String   @id @default(uuid())
  userId    String
  serverId  String
  role      String   // "OWNER" | "ADMIN" | "MEMBER"
  joinedAt  DateTime @default(now())

  // Relations
  user   User   @relation("UserMemberships", fields: [userId], references: [id], onDelete: Cascade)
  server Server @relation("ServerMemberships", fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([userId, serverId])
}

model Invitation {
  id        String    @id @default(uuid())
  code      String    @unique          
  serverId  String                     
  expiresAt DateTime?                  
  createdAt DateTime  @default(now())

  // Relations
  server Server @relation("ServerInvitations", fields: [serverId], references: [id], onDelete: Cascade)
}

model ServerBan {
  id          String    @id @default(uuid())
  userId      String
  serverId    String
  bannedById  String
  bannedAt    DateTime  @default(now())
  bannedUntil DateTime?

  // Relations
  user     User   @relation("BansReceived", fields: [userId],    references: [id], onDelete: Cascade)
  server   Server @relation("ServerBans",   fields: [serverId],  references: [id], onDelete: Cascade)
  bannedBy User   @relation("BansGiven",    fields: [bannedById], references: [id], onDelete: Cascade)

  @@unique([userId, serverId])
}